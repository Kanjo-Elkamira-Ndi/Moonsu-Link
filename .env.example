# ─── DATABASE ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/agribridge
DATABASE_POOL_MAX=10

# ─── API SERVER ─────────────────────────────────────────────────────────────
API_PORT=3001
API_SECRET=your_api_secret_here
NODE_ENV=development

# ─── TELEGRAM ───────────────────────────────────────────────────────────────
# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ─── SMS — TWILIO (for MTN/Orange/Camtel via international gateway) ──────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ─── SMS — LOCAL CAMEROONIAN GATEWAYS (alternative/future) ──────────────────
# MTN Cameroon SMS API (request access at developer.mtn.com)
MTN_SMS_API_KEY=your_mtn_api_key
MTN_SMS_API_URL=https://api.mtn.com/v1/sms/messages

# Orange Cameroon SMS API (request access at developer.orange.com)
ORANGE_SMS_API_KEY=your_orange_api_key
ORANGE_SMS_CLIENT_ID=your_orange_client_id
ORANGE_SMS_CLIENT_SECRET=your_orange_client_secret

# ─── WHATSAPP (future — requires Meta Business verification) ─────────────────
# WHATSAPP_TOKEN=your_whatsapp_token
# WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
# WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token

# ─── ADMIN DASHBOARD ────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password
ADMIN_JWT_SECRET=your_jwt_secret_here

# ─── VITE (admin frontend — must be prefixed with VITE_) ────────────────────
VITE_API_URL=http://localhost:3001
